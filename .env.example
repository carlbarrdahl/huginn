# LLM
ANTHROPIC_API_KEY=

# GitHub API (optional, avoids rate limiting)
GITHUB_TOKEN=

# Chain ID (31337=hardhat, 84532=baseSepolia)
CHAIN_ID=31337
HARDHAT_RPC_URL=http://127.0.0.1:8545
BASE_SEPOLIA_RPC_URL=       # e.g. https://base-sepolia.infura.io/v3/YOUR_KEY

# Agent wallet
AGENT_PRIVATE_KEY=          # 0x-prefixed private key for tx signing

# Curator Studio
CURATOR_TENANT=             # Tenant ENS name — e.g. huginn.eth or support.eth
CURATOR_UPLOAD_URL=         # Metadata upload endpoint — e.g. https://curate-fund.vercel.app/api/upload/metadata
CURATOR_UPLOAD_SECRET=      # Shared secret for the upload endpoint
CURATOR_INDEXER_URL=        # Indexer GraphQL endpoint — e.g. http://localhost:42069/graphql
